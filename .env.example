# === 資料庫 ===
# 開發：SQLite（預設）；正式：Supabase Postgres 連線字串（並將 prisma/schema.prisma 的 provider 改為 postgresql）
DATABASE_URL="file:./dev.db"

# === Session ===
# 簽署登入 cookie 用，隨機長字串（openssl rand -hex 32）
SESSION_SECRET="change-me-to-a-long-random-string"

# === 開發模式 ===
# true 時開放 /dev-login 假登入（可選任一 seed 成員身分）；正式環境務必移除
DEV_AUTH="true"

# === LINE（Phase 3，未設定時功能自動停用）===
# LINE Login channel
LINE_LOGIN_CHANNEL_ID=""
LINE_LOGIN_CHANNEL_SECRET=""
# LINE 官方帳號 Messaging API
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_CHANNEL_SECRET=""
# 部署後的完整網址（LINE OAuth callback 用），例 https://bni-tool.vercel.app
APP_BASE_URL="http://localhost:3300"

# === Cron（每日提醒）===
# Vercel Cron 呼叫 /api/cron/reminders 時的驗證用密鑰
CRON_SECRET=""
